{
  "mcpServers": {
    "dj-techno": {
      "type": "http",
      "url": "http://localhost:9100/mcp"
    },
    "sqlite-db": {
      "command": "sh",
      "args": [
        "-c",
        "npx -y mcp-server-sqlite-npx \"$DJ_DB_PATH\""
      ],
      "env": {
        "DJ_DB_PATH": "${DJ_DB_PATH}"
      }
    },
    "in-memoria": {
      "command": "sh",
      "args": [
        "-c",
        "cd /Users/laptop/dev/dj-techno-set-builder && in-memoria server"
      ],
      "env": {
        "SURREAL_SYNC_DATA": "true"
      }
    }
  }
}
