# Application
APP_NAME=dj-techno-set-builder
APP_ENV=dev
DEBUG=true
LOG_LEVEL=INFO

# Database
DATABASE_URL=sqlite+aiosqlite:///./dev.db
# Use PostgreSQL URL for Alembic migrations (schema_v6 is Postgres-specific).
# Example: postgresql+asyncpg://postgres:postgres@localhost:5432/dj_techno
ALEMBIC_DATABASE_URL=
