# Core app
DATABASE_URL=sqlite+aiosqlite:///./dev.db

# Yandex Music
YANDEX_MUSIC_TOKEN=
YANDEX_MUSIC_USER_ID=
YANDEX_MUSIC_BASE_URL=https://api.music.yandex.net:443

# SoundCloud (for scripts/soundcloud_smoke.py)
SOUNDCLOUD_CLIENT_ID=
SOUNDCLOUD_CLIENT_SECRET=
SOUNDCLOUD_OAUTH_URL=https://secure.soundcloud.com/oauth/token
SOUNDCLOUD_API_BASE_URL=https://api.soundcloud.com

# Sentry (leave empty to disable)
SENTRY_DSN=
ENVIRONMENT=development

# OpenTelemetry (leave empty to disable OTLP exporter)
OTEL_ENDPOINT=
OTEL_SERVICE_NAME=dj-set-builder-mcp

# MCP Observability
MCP_CACHE_DIR=./cache/mcp
MCP_CACHE_TTL_TOOLS=60
MCP_CACHE_TTL_RESOURCES=300
MCP_RETRY_MAX=3
MCP_RETRY_BACKOFF=1.0
MCP_PING_INTERVAL=30
MCP_LOG_PAYLOADS=false

# Pagination
MCP_PAGE_SIZE=50
